- rule_id: PGM024
  severity: Critical
  message: "REINDEX SCHEMA 'public' without CONCURRENTLY acquires ACCESS EXCLUSIVE lock, blocking all reads and writes. Use REINDEX SCHEMA CONCURRENTLY 'public' (PostgreSQL 12+)."
  file: migrations/010.sql
  start_line: 1
  end_line: 1
